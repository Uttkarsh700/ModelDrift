# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/modeldrift

# Redis
REDIS_URL=redis://localhost:6379

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# FastAPI
DEBUG=true
API_TITLE=ModelDrift API
API_VERSION=0.1.0

# Frontend
VITE_API_URL=http://localhost:8000

# GitHub Actions (optional - for triggering workflows from backend)
# Get GITHUB_TOKEN from: https://github.com/settings/tokens (needs workflows scope)
GITHUB_TOKEN=
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=ModelDrift
GITHUB_WORKFLOW_FILE=retrain-model.yml
GITHUB_REF=main
